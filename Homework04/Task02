# 2 პაროლის შეფასება
# ამოცანა: მომხმარებლის შეყვანილი პაროლი შეაფასე 0–10 შკალით: სიგრძე, ციფრები, სიმბოლოები,
# დიდი/პატარა ასოები, განმეორებადი სიმბოლოების არსებობა.
# მოთხოვნები: გამოიტანე “weak/medium/strong”.

import string

password = input("your password: ")

has_digits = any(char in string.digits for char in password)
has_lowercase = any(char in string.ascii_lowercase for char in password)
has_uppercase = any(char in string.ascii_uppercase for char in password)
has_symbols = any(char in string.punctuation for char in password)
has_repeating = any(password.count(char) > 1 for char in password)

score = 0

if len(password) >= 8:
    score += 2
if len(password) >= 12:
    score += 2
if has_digits:
    score += 1
if has_lowercase:
    score += 1
if has_uppercase:
    score += 1
if has_symbols:
    score += 2
if has_repeating:
    score -= 1
if "password" in password or "123456" in password or "qwerty" in password.lower():
    score -= 2

score = max(0, min(10, score))
print(f"score: {score}/10")

if score <= 3:
    print("WEAK")
elif 4 <= score <= 6:
    print("MEDIUM")
else:
    print("STRONG")