   valid = True
   for x in numbers:
       if not x.isdigit():
           print(f"'{x}' is not a valid number! try again.")
           valid = False
           break
      
   if valid:
       numbers = [int(x) for x in numbers]
       choose_order =  input("Choose order (asc/desc/rand/unique): ")


       if choose_order == "asc":
           print(f"Ascending - {sorted(numbers)}")
       elif choose_order == "desc":
           print(f"Descending - {sorted(numbers, reverse = True)}")
